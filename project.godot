; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value

config_version=5

[application]

config/name="GloryProtect"
run/main_scene="res://scenes/app/app_shell.tscn"
config/features=PackedStringArray("4.6")

[autoload]

AppSettings="*res://scripts/settings/app_settings.gd"
PlatformPostLayout="*res://scripts/platform/platform_post_layout.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.035, 0.047, 0.075, 1)
