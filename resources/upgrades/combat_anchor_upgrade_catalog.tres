[gd_resource type="Resource" script_class="UpgradeCatalog" load_steps=32 format=3]

[ext_resource type="Script" path="res://scripts/upgrades/upgrade_catalog.gd" id="1_catalog"]
[ext_resource type="Script" path="res://scripts/upgrades/upgrade_definition.gd" id="2_definition"]
[ext_resource type="Script" path="res://scripts/upgrades/upgrade_effect_definition.gd" id="3_effect"]

[sub_resource type="Resource" id="EffectOverloadBasic"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_reinforced_wind_threshold"

[sub_resource type="Resource" id="CardOverloadBasic"]
script = ExtResource("2_definition")
card_id = &"anchor_overload_basic"
branch_id = &"anchors"
title = "Усиленное закрепление"
description = "Трос начинает рваться только при силе ветра 3 вместо 2. Количество лебёдок не меняется."
card_type = 1
effect = SubResource("EffectOverloadBasic")

[sub_resource type="Resource" id="EffectOverloadAdvanced"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_second_winch_pair"

[sub_resource type="Resource" id="CardOverloadAdvanced"]
script = ExtResource("2_definition")
card_id = &"anchor_overload_advanced"
branch_id = &"anchors"
title = "Мега закрепление"
description = "Открывает вторую лебёдку с каждой стороны платформы."
card_type = 2
prerequisite_card_ids = Array[StringName]([&"anchor_overload_basic"])
effect = SubResource("EffectOverloadAdvanced")

[sub_resource type="Resource" id="EffectPeriodicBasic"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_periodic_electric"

[sub_resource type="Resource" id="CardPeriodicBasic"]
script = ExtResource("2_definition")
card_id = &"anchor_periodic_electric_basic"
branch_id = &"anchors"
title = "Электрифицированный трос"
description = "Закреплённый трос наносит поднимающимся врагам 1 урон раз в 4 секунды."
card_type = 1
effect = SubResource("EffectPeriodicBasic")

[sub_resource type="Resource" id="EffectPeriodicAdvanced"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_periodic_electric_advanced"

[sub_resource type="Resource" id="CardPeriodicAdvanced"]
script = ExtResource("2_definition")
card_id = &"anchor_periodic_electric_advanced"
branch_id = &"anchors"
title = "Улучшенный электрифицированный трос"
description = "Электрический импульс троса срабатывает каждые 2 секунды вместо 4. Урон остаётся равен 1."
card_type = 2
prerequisite_card_ids = Array[StringName]([&"anchor_periodic_electric_basic"])
effect = SubResource("EffectPeriodicAdvanced")

[sub_resource type="Resource" id="EffectInstallBasic"]
script = ExtResource("3_effect")
effect_type = 4
target_id = &"anchor_install_speed_bonus_ratio"
scalar_value = 0.2

[sub_resource type="Resource" id="CardInstallBasic"]
script = ExtResource("2_definition")
card_id = &"anchor_install_speed_basic"
branch_id = &"anchors"
title = "Ускоренное закрепление"
description = "Скорость закрепления всех якорей увеличена на 20%."
card_type = 1
effect = SubResource("EffectInstallBasic")

[sub_resource type="Resource" id="EffectInstallAdvanced"]
script = ExtResource("3_effect")
effect_type = 4
target_id = &"anchor_install_speed_bonus_ratio"
scalar_value = 0.2

[sub_resource type="Resource" id="CardInstallAdvanced"]
script = ExtResource("2_definition")
card_id = &"anchor_install_speed_advanced"
branch_id = &"anchors"
title = "Турбо закрепление"
description = "Скорость закрепления всех якорей дополнительно увеличена на 20%."
card_type = 2
prerequisite_card_ids = Array[StringName]([&"anchor_install_speed_basic"])
effect = SubResource("EffectInstallAdvanced")

[sub_resource type="Resource" id="EffectInstantRemove"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_instant_remove_all"

[sub_resource type="Resource" id="CardInstantRemove"]
script = ExtResource("2_definition")
card_id = &"anchor_instant_remove_all"
branch_id = &"anchors"
title = "Мгновенное снятие"
description = "Экстренная команда сразу снимает закреплённые якоря обеих сторон без операторов. Начатая установка завершается и затем сразу снимается."
card_type = 3
effect = SubResource("EffectInstantRemove")

[sub_resource type="Resource" id="EffectStrongSpecialization"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_specialization_strong"

[sub_resource type="Resource" id="CardStrongSpecialization"]
script = ExtResource("2_definition")
card_id = &"anchor_specialization_strong"
branch_id = &"anchors"
title = "Усиленные лебёдки"
description = "Окно перегрузки одиночного якоря увеличено ещё на 1 секунду."
card_type = 4
closes_specialization_ids = Array[StringName]([&"anchor_specialization_electric", &"anchor_specialization_trap"])
effect = SubResource("EffectStrongSpecialization")

[sub_resource type="Resource" id="EffectElectricSpecialization"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_specialization_electric"

[sub_resource type="Resource" id="CardElectricSpecialization"]
script = ExtResource("2_definition")
card_id = &"anchor_specialization_electric"
branch_id = &"anchors"
title = "Импульсные лебёдки"
description = "Крепление создаёт наземный импульс в радиусе 240: 1 урон и 30% шанс оглушить врага на 2 секунды."
card_type = 4
closes_specialization_ids = Array[StringName]([&"anchor_specialization_strong", &"anchor_specialization_trap"])
effect = SubResource("EffectElectricSpecialization")

[sub_resource type="Resource" id="EffectTrapSpecialization"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_specialization_trap"

[sub_resource type="Resource" id="CardTrapSpecialization"]
script = ExtResource("2_definition")
card_id = &"anchor_specialization_trap"
branch_id = &"anchors"
title = "Лебёдки-ловушки"
description = "Крепление и снятие создают взрыв у наземной точки: радиус 240, 1 урон и отбрасывание врагов по земле на 300."
card_type = 4
closes_specialization_ids = Array[StringName]([&"anchor_specialization_strong", &"anchor_specialization_electric"])
effect = SubResource("EffectTrapSpecialization")

[sub_resource type="Resource" id="EffectStrongSecondInstall"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_strong_second_install"

[sub_resource type="Resource" id="CardStrongSecondInstall"]
script = ExtResource("2_definition")
card_id = &"anchor_strong_second_install"
branch_id = &"anchors"
title = "Парная установка"
description = "Второй якорь той же стороны устанавливается на 50% быстрее, а враг при начале подъёма имеет +25% шанс сорваться с троса."
card_type = 5
required_specialization_id = &"anchor_specialization_strong"
effect = SubResource("EffectStrongSecondInstall")

[sub_resource type="Resource" id="EffectStrongClimberFall"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_strong_climber_fall"

[sub_resource type="Resource" id="CardStrongClimberFall"]
script = ExtResource("2_definition")
card_id = &"anchor_strong_climber_fall"
branch_id = &"anchors"
title = "Нестабильный подъём"
description = "При начале подъёма враг имеет 25% шанс сорваться с троса."
card_type = 5
required_specialization_id = &"anchor_specialization_strong"
effect = SubResource("EffectStrongClimberFall")

[sub_resource type="Resource" id="EffectElectricDrop"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_electric_drop"

[sub_resource type="Resource" id="CardElectricDrop"]
script = ExtResource("2_definition")
card_id = &"anchor_electric_drop"
branch_id = &"anchors"
title = "Сбрасывающий разряд"
description = "Каждые 2 секунды по закреплённому тросу проходит сбрасывающий импульс с 50% шансом сбросить врага."
card_type = 5
required_specialization_id = &"anchor_specialization_electric"
effect = SubResource("EffectElectricDrop")

[sub_resource type="Resource" id="EffectTrapAttachExplosion"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchor_trap_attach_explosion"

[sub_resource type="Resource" id="CardTrapAttachExplosion"]
script = ExtResource("2_definition")
card_id = &"anchor_trap_attach_explosion"
branch_id = &"anchors"
title = "Взрывное закрепление"
description = "При успешном закреплении взрыв возле наземной точки наносит 1 урон."
card_type = 5
required_specialization_id = &"anchor_specialization_trap"
effect = SubResource("EffectTrapAttachExplosion")

[resource]
script = ExtResource("1_catalog")
definitions = Array[ExtResource("2_definition")]([SubResource("CardOverloadBasic"), SubResource("CardOverloadAdvanced"), SubResource("CardPeriodicBasic"), SubResource("CardPeriodicAdvanced"), SubResource("CardInstallBasic"), SubResource("CardInstallAdvanced"), SubResource("CardInstantRemove"), SubResource("CardStrongSpecialization"), SubResource("CardElectricSpecialization"), SubResource("CardTrapSpecialization"), SubResource("CardStrongSecondInstall"), SubResource("CardStrongClimberFall"), SubResource("CardElectricDrop"), SubResource("CardTrapAttachExplosion")])