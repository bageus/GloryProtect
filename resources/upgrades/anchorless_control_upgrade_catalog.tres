description = "При движении платформа сбивает наземных врагов перед собой."
card_type = 5
required_specialization_id = &"anchorless_specialization_speed"
effect = SubResource("EffectFrontSweep")

[sub_resource type="Resource" id="EffectGroundCore"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_powerful_ground_core"

[sub_resource type="Resource" id="CardGroundCore"]
