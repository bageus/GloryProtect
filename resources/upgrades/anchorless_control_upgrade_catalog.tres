card_id = &"anchorless_specialization_powerful"
branch_id = &"steering"
title = "Мощная стабилизация"
description = "При подключении разряд наносит 1 урон врагам возле последней точки якоря каждой стороны."
card_type = 4
closes_specialization_ids = Array[StringName]([&"anchorless_specialization_precise", &"anchorless_specialization_speed"])
effect = SubResource("EffectPowerful")

[sub_resource type="Resource" id="EffectPreciseRecharge"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_precise_recharge"

