[sub_resource type="Resource" id="EffectAutoSteering"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_auto_steering"

[sub_resource type="Resource" id="CardAutoSteering"]
script = ExtResource("2_definition")
card_id = &"anchorless_auto_steering"
branch_id = &"steering"
title = "Автоматическое подруливание"
description = "Платформа игнорирует ветер силы 1. Рулевой всё ещё обязателен; автоматического движения и фиксации нет."
card_type = 3
required_completed_branch_id = &"steering"
effect = SubResource("EffectAutoSteering")

[sub_resource type="Resource" id="EffectPrecise"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_specialization_precise"

[sub_resource type="Resource" id="CardPrecise"]
script = ExtResource("2_definition")
card_id = &"anchorless_specialization_precise"
branch_id = &"steering"
title = "Точная стабилизация"
description = "Инерция снижена на 25%."
card_type = 4
closes_specialization_ids = Array[StringName]([&"anchorless_specialization_speed", &"anchorless_specialization_powerful"])
effect = SubResource("EffectPrecise")

[sub_resource type="Resource" id="EffectSpeed"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_specialization_speed"

[sub_resource type="Resource" id="CardSpeed"]
script = ExtResource("2_definition")
card_id = &"anchorless_specialization_speed"
branch_id = &"steering"
title = "Скоростной перелёт"
description = "+15% к ускорению и максимальной скорости; при подключении скорость резко сбрасывается."
card_type = 4
closes_specialization_ids = Array[StringName]([&"anchorless_specialization_precise", &"anchorless_specialization_powerful"])
effect = SubResource("EffectSpeed")

[sub_resource type="Resource" id="EffectPowerful"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_specialization_powerful"

[sub_resource type="Resource" id="CardPowerful"]
