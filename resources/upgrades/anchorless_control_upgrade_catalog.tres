description = "После прекращения ввода горизонтальная скорость снижается на 20% быстрее."
card_type = 1
effect = SubResource("EffectDragBasic")

[sub_resource type="Resource" id="EffectDragAdvanced"]
script = ExtResource("3_effect")
effect_type = 4
target_id = &"anchorless_release_drag_bonus_ratio"
scalar_value = 0.2

[sub_resource type="Resource" id="CardDragAdvanced"]
