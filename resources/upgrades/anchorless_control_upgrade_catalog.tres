[gd_resource type="Resource" script_class="UpgradeCatalog" load_steps=34 format=3]

[ext_resource type="Script" path="res://scripts/upgrades/upgrade_catalog.gd" id="1_catalog"]
[ext_resource type="Script" path="res://scripts/upgrades/upgrade_definition.gd" id="2_definition"]
[ext_resource type="Script" path="res://scripts/upgrades/upgrade_effect_definition.gd" id="3_effect"]

[sub_resource type="Resource" id="EffectSteeringBasic"]
script = ExtResource("3_effect")
effect_type = 4
target_id = &"anchorless_steering_force_bonus_ratio"
scalar_value = 0.1

[sub_resource type="Resource" id="CardSteeringBasic"]
script = ExtResource("2_definition")
card_id = &"anchorless_steering_force_basic"
branch_id = &"steering"
title = "Усиленный рулевой привод"
description = "Управляющая сила увеличена на 10%."
card_type = 1
effect = SubResource("EffectSteeringBasic")

[sub_resource type="Resource" id="EffectSteeringAdvanced"]
script = ExtResource("3_effect")
effect_type = 4
target_id = &"anchorless_steering_force_bonus_ratio"
