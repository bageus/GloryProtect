card_id = &"anchorless_precise_recharge"
branch_id = &"steering"
title = "Центральный резонанс"
description = "Около центра зоны контакта скорость восстановления щита увеличена на 25%."
card_type = 5
required_specialization_id = &"anchorless_specialization_precise"
effect = SubResource("EffectPreciseRecharge")

[sub_resource type="Resource" id="EffectLongFlight"]
