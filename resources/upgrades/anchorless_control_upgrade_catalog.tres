required_specialization_id = &"anchorless_specialization_powerful"
effect = SubResource("EffectGroundCore")

[sub_resource type="Resource" id="EffectPlatformCore"]
script = ExtResource("3_effect")
effect_type = 3
target_id = &"anchorless_powerful_platform_core"

[sub_resource type="Resource" id="CardPlatformCore"]
