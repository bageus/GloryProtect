[resource]
script = ExtResource("1_catalog")
definitions = Array[ExtResource("2_definition")]([SubResource("CardSteeringBasic"), SubResource("CardSteeringAdvanced"), SubResource("CardWindBasic"), SubResource("CardWindAdvanced"), SubResource("CardDragBasic"), SubResource("CardDragAdvanced"), SubResource("CardAutoSteering"), SubResource("CardPrecise"), SubResource("CardSpeed"), SubResource("CardPowerful"), SubResource("CardPreciseRecharge"), SubResource("CardLongFlight"), SubResource("CardFrontSweep"), SubResource("CardGroundCore"), SubResource("CardPlatformCore")])
