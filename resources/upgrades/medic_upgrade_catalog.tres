script = ExtResource("1_catalog")
definitions = Array[ExtResource("2_definition")]([SubResource("CardStation"), SubResource("CardHealBasic"), SubResource("CardHealAdvanced"), SubResource("CardSpeedBasic"), SubResource("CardSpeedAdvanced"), SubResource("CardRangeBasic"), SubResource("CardRangeAdvanced"), SubResource("CardHealth"), SubResource("CardArmor"), SubResource("CardField"), SubResource("CardStimulant"), SubResource("CardProtective"), SubResource("CardFieldCombat"), SubResource("CardFieldEmergency"), SubResource("CardRevival"), SubResource("CardChain")])
