[gd_resource type="Resource" script_class="UpgradeCatalog" load_steps=36 format=3]

[ext_resource type="Script" path="res://scripts/upgrades/upgrade_catalog.gd" id="1_catalog"]
[ext_resource type="Script" path="res://scripts/upgrades/upgrade_definition.gd" id="2_definition"]
[ext_resource type="Script" path="res://scripts/upgrades/upgrade_effect_definition.gd" id="3_effect"]

[sub_resource type="Resource" id="EffectStation"]
script = ExtResource("3_effect")
effect_type = 1
integer_value = 1
buildable_type_id = 0

[sub_resource type="Resource" id="CardStation"]
script = ExtResource("2_definition")
card_id = &"medic_station"
branch_id = &"healer"
title = "Пост лекаря"
description = "Открывает один медицинский пост, роль лекаря и три базовые линии ветки."
card_type = 0
effect = SubResource("EffectStation")

[sub_resource type="Resource" id="EffectHealBasic"]
script = ExtResource("3_effect")
effect_type = 4
target_id = &"medic_heal_amount_bonus"
scalar_value = 1.0

